# Example env values for backend email sending
# Copy this to .env and fill real values before starting the server

# Brevo (Sendinblue) API key and verified sender
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=info@avcareerz.com
BREVO_SENDER_NAME="AVcareerz"

# Optional public logo URL used in emails (must be absolute https url)
EMAIL_LOGO_URL=https://avcareerz.com/images/logonew.png

# Admin receiving email(s) - comma separated
ADMIN_EMAIL=info@avcareerz.com
# or multiple admins
#ADMIN_EMAILS=admin1@example.com,admin2@example.com

# (Optional) legacy Gmail SMTP fallback
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=yourgmailapppassword
PORT=10000
FRONTEND_URL=https://avcareerz.com
ALLOW_NULL_ORIGIN=1

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=avcareerz_db
DB_SSL=false

# Secrets
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
ADMIN_WHATSAPPS=+917036777567

# Email configuration
# The code will try Brevo first; if BREVO_API_KEY and BREVO_SENDER_EMAIL
# are set it will use Brevo's SMTP API.  If those are missing but
# EMAIL_USER/EMAIL_PASS are provided (Gmail credentials), it will fall
# back to sending via Gmail using nodemailer.
EMAIL_USER=
EMAIL_PASS=
BREVO_API_KEY=
BREVO_SENDER_EMAIL=Info@avcareerz.com
BREVO_SENDER_NAME=
# Comma-separated admin notification inboxes
ADMIN_EMAILS=Info@avcareerz.com

RESEND_API_KEY=
RESET_PASSWORD_PEPPER=secret
